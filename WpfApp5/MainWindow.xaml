<Window x:Class="WpfApp5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="450" Width="800">

    <Canvas Background="LightBlue" Margin="178,120,178,117">
        <Ellipse x:Name="MyEllipse"
            Canvas.Left="185" Canvas.Top="89"
            Width="45" Height="74" 
            Fill="Orange"
            MouseDown="Ellipse_MouseDown" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="EllipseRotate" Angle="135" CenterX="25" CenterY="25"/>
            </Ellipse.RenderTransform>
        </Ellipse>
    </Canvas>
</Window>